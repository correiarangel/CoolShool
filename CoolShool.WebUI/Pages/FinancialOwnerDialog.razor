@using MudBlazor
@using CoolShool.WebUI

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(OwnerId == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @(_title)
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="@_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Nome Completo" @bind-Value="OwnerName" Required="true" 
                          RequiredError="O nome é obrigatório" Margin="Margin.Normal" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success || _processing)" 
                   Class="rounded-pill px-6">
            @if (_processing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <MudText>Salvar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

