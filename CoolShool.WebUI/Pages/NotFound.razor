@page "/not-found"
@layout MainLayout

<div class="not-found-container">
    <div class="not-found-content">
        <div class="error-code">
            <span class="digit">4</span>
            <span class="digit ghost">0</span>
            <span class="digit">4</span>
        </div>

        <div class="ghost-wrapper">
            <div class="ghost">
                <div class="ghost-eyes">
                    <div class="ghost-eye"></div>
                    <div class="ghost-eye"></div>
                </div>
                <div class="ghost-mouth"></div>
                <div class="ghost-feet">
                    <div class="ghost-foot"></div>
                    <div class="ghost-foot"></div>
                    <div class="ghost-foot"></div>
                </div>
            </div>
            <div class="ghost-shadow"></div>
        </div>

        <h1 class="not-found-title">Oops! Página não encontrada</h1>
        <p class="not-found-subtitle">
            Parece que um fantasma levou a página que você estava procurando. 👻
        </p>
        <p class="not-found-description">
            A página pode ter sido removida, renomeada ou talvez nunca tenha existido.
        </p>

        <div class="not-found-actions">
            <a href="/" class="btn-home">
                <span class="btn-icon">🏠</span> Voltar para o início
            </a>
            <button class="btn-back" onclick="history.back()">
                <span class="btn-icon">⬅️</span> Voltar à página anterior
            </button>
        </div>
    </div>
</div>

<style>
    .not-found-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        padding: 2rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
    }

    .not-found-content {
        text-align: center;
        max-width: 600px;
        animation: fadeInUp 0.8s ease-out;
    }

    .error-code {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .digit {
        font-size: 8rem;
        font-weight: 900;
        color: #4a90d9;
        line-height: 1;
        text-shadow: 4px 4px 0px #2563a8;
        animation: pulse 2s infinite;
    }

    .digit.ghost {
        color: transparent;
        text-shadow: none;
    }

    /* Ghost */
    .ghost-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: -4rem auto 1rem;
        width: 80px;
    }

    .ghost {
        width: 70px;
        height: 80px;
        background: #b0c4de;
        border-radius: 35px 35px 0 0;
        position: relative;
        animation: float 3s ease-in-out infinite;
        box-shadow: 0 8px 24px rgba(74, 144, 217, 0.3);
    }

    .ghost::before {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 100%;
        height: 20px;
        background:
            radial-gradient(circle at 12px 0, #b0c4de 12px, transparent 13px),
            radial-gradient(circle at 35px 0, #e8ecf1 12px, transparent 13px),
            radial-gradient(circle at 58px 0, #b0c4de 12px, transparent 13px);
    }

    .ghost-eyes {
        display: flex;
        justify-content: space-around;
        padding: 22px 14px 0;
    }

    .ghost-eye {
        width: 16px;
        height: 18px;
        background: #2563a8;
        border-radius: 50%;
        animation: blink 4s infinite;
    }

    .ghost-mouth {
        width: 24px;
        height: 12px;
        border-radius: 0 0 12px 12px;
        background: #2563a8;
        margin: 6px auto 0;
    }

    .ghost-feet {
        display: flex;
        justify-content: space-around;
        position: absolute;
        bottom: -14px;
        width: 100%;
    }

    .ghost-foot {
        width: 22px;
        height: 14px;
        background: #b0c4de;
        border-radius: 0 0 11px 11px;
    }

    .ghost-shadow {
        width: 50px;
        height: 14px;
        background: rgba(37, 99, 168, 0.15);
        border-radius: 50%;
        margin-top: 8px;
        animation: shadow 3s ease-in-out infinite;
    }

    .not-found-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1e3a5f;
        margin: 1.5rem 0 0.75rem;
    }

    .not-found-subtitle {
        font-size: 1.15rem;
        color: #4a6fa5;
        margin-bottom: 0.5rem;
    }

    .not-found-description {
        font-size: 0.95rem;
        color: #7a90aa;
        margin-bottom: 2rem;
    }

    .not-found-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-home, .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.75rem;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
    }

    .btn-home {
        background: linear-gradient(135deg, #4a90d9, #2563a8);
        color: white;
        box-shadow: 0 4px 15px rgba(74, 144, 217, 0.4);
    }

    .btn-home:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(74, 144, 217, 0.5);
        color: white;
        text-decoration: none;
    }

    .btn-back {
        background: white;
        color: #4a90d9;
        border: 2px solid #4a90d9;
        box-shadow: 0 4px 15px rgba(74, 144, 217, 0.15);
    }

    .btn-back:hover {
        background: #f0f6ff;
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(74, 144, 217, 0.25);
    }

    .btn-icon {
        font-size: 1.1rem;
    }

    /* Animations */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-12px); }
    }

    @@keyframes shadow {
        0%, 100% { transform: scaleX(1); opacity: 0.15; }
        50%       { transform: scaleX(0.7); opacity: 0.08; }
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50%       { transform: scale(1.04); }
    }

    @@keyframes blink {
        0%, 96%, 100% { transform: scaleY(1); }
        98%            { transform: scaleY(0.1); }
    }
</style>
